---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Base title="Writing — Nolan Nichols" description="Notes on the semantic web, knowledge graphs, and biomedical data.">
  <h1>Writing</h1>
  <ul class="post-list">
    {posts.map((p) => (
      <li>
        <a href={`/blog/${p.id}`}>{p.data.title}</a>
        <div class="when">
          {p.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          {p.data.category ? ` · ${p.data.category}` : ''}
        </div>
        {p.data.description && <p class="meta">{p.data.description}</p>}
      </li>
    ))}
  </ul>
</Base>
